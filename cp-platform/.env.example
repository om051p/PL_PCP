# Firebase Configuration
# Get these values from Firebase Console → Project Settings → General → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: Firebase Auth Emulator (for local development)
# Set to http://localhost:9099 to use the Firebase Auth emulator
# VITE_FIREBASE_AUTH_EMULATOR=http://localhost:9099

# Optional: Firebase App Check (for production)
# Requires reCAPTCHA v3 site key from Firebase Console → App Check → Setup
# VITE_RECAPTCHA_SITE_KEY=
