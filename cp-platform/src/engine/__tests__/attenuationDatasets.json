        "surfaceAreaToX_M2":             59862.664893098197,
        "currentRequiredToX_A":          10.475966356292183,
        "currentRequiredTotal_A":        18.437700787074245,
        "unitPipeResistance_OhmPerM":     2.432727502628338e-6,
        "coatingLeakageResistance_OhmM": 1392.0752355771112,
        "alpha":                          4.1803763170231051e-5,
        "deltaE0_V":                      0.55,
        "deltaERequired_V":               0.45
      },
      "expectedCheckPoint": {
        "checkPointKm":               25,
        "deltaECalculated_V":          0.34425295624970809,
        "potentialCalculated_mV":    894.25295624970813,
        "criterionMet":              false,
        "comment": "Single-station check point fails — requires combined station coverage"
