rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: get the authenticated user's profile document
    function getUserRecord() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper: verify user exists, is approved, and status is active
    function isApproved() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserRecord().get('approved', false) == true &&
        getUserRecord().get('status', '') == 'active';
    }

    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Users Collection
    match /users/{userId} {
      // Allow read if authenticated and in same organization (or reading self)
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         getUserRecord().get('organizationId', '') == resource.data.get('organizationId', ''))
      );

      // Allow self-registration or admin bootstrap creation
      allow create: if request.auth != null && request.auth.uid == userId && (
        // Self registration: must be pending engineer under 'ikk' organization
        (request.resource.data.approved == false &&
         request.resource.data.status == 'pending' &&
         request.resource.data.role == 'engineer' &&
         request.resource.data.organizationId == 'ikk') ||
        // Bootstrap: specifically allowed for rahul.panchel@ikkgroup.com
        (request.auth.token.email == 'rahul.panchel@ikkgroup.com')
      );

      // Allow updates by admin (in same org) or self (without self-escalation)
      allow update: if request.auth != null && (
        // Admin update within same organization
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         getUserRecord().role == 'admin' &&
         getUserRecord().organizationId == resource.data.organizationId &&
         getUserRecord().organizationId == request.resource.data.organizationId) ||
        // Self update: displayName only, preventing self-role-escalation/self-approval
        (request.auth.uid == userId &&
         request.resource.data.get('role', resource.data.role) == resource.data.role &&
         request.resource.data.get('approved', resource.data.approved) == resource.data.approved &&
         request.resource.data.get('status', resource.data.status) == resource.data.status &&
         request.resource.data.get('organizationId', resource.data.organizationId) == resource.data.organizationId)
      );

      allow delete: if false;
    }

    // Projects Collection
    match /projects/{projectId} {
      allow read: if isApproved() && getUserRecord().get('organizationId', '') == resource.data.get('organizationId', '');
      
      allow create: if isApproved() && 
        request.resource.data.get('organizationId', '') == getUserRecord().get('organizationId', '') &&
        getUserRecord().get('role', '') in ['admin', 'manager', 'engineer'];

      allow update: if isApproved() && 
        resource.data.get('organizationId', '') == getUserRecord().get('organizationId', '') &&
        request.resource.data.get('organizationId', '') == getUserRecord().get('organizationId', '') &&
        getUserRecord().get('role', '') in ['admin', 'manager', 'engineer'];

      allow delete: if isApproved() && 
        resource.data.get('organizationId', '') == getUserRecord().get('organizationId', '') &&
        getUserRecord().get('role', '') in ['admin', 'manager'];

      // Nested Subcollections (inherit parent project organization checks)
      match /stations/{stationId} {
        allow read, write: if isApproved() &&
          get(/databases/$(database)/documents/projects/$(projectId)).data.get('organizationId', '') == getUserRecord().get('organizationId', '');
      }

      match /revisions/{revisionId} {
        allow read, write: if isApproved() &&
          get(/databases/$(database)/documents/projects/$(projectId)).data.get('organizationId', '') == getUserRecord().get('organizationId', '');
      }
    }

    // Audit Logs (Write-only / Immutable once created; read-only for Admins)
    match /audit_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if isApproved() && getUserRecord().get('role', '') == 'admin';
      allow update, delete: if false;
    }
  }
}
